# Development Dockerfile for Spring Boot application
# 이 Dockerfile은 devtools를 통한 핫 리로딩 및 디버깅을 지원하는 로컬 개발에 최적화되어 있습니다.
# 소스 코드는 볼륨으로 마운트되어 실시간 변경 사항을 반영합니다.

# Java 21 SDK가 포함된 기본 이미지 사용
FROM openjdk:21-jdk-slim

# 컨테이너 내부의 작업 디렉토리 설정
WORKDIR /app

# Gradle wrapper 및 빌드 파일 복사
# 이는 Gradle 의존성 캐싱 및 컨테이너 내에서 Gradle 명령 실행에 도움이 됩니다.
COPY gradlew .
COPY gradle gradle/
COPY build.gradle .
COPY settings.gradle .

# 소스 코드 복사 (docker-compose에서 볼륨 마운트로 덮어씌워져 실시간 변경 반영)
COPY src src/

# Spring Boot 애플리케이션 및 원격 디버깅을 위한 포트 노출
EXPOSE 8080
EXPOSE 5005

# 애플리케이션 실행 명령어
# --debug-jvm은 디버깅 포트 5005를 엽니다.
# --args='--spring.devtools.restart.enabled=true'는 devtools 핫 리로딩을 활성화합니다.
# 개발 시에는 bootRun을 사용하여 컴파일 및 실행을 처리합니다.
CMD ["./gradlew", "bootRun", "--debug-jvm", "--args='--spring.devtools.restart.enabled=true'"]
# 참고: application.properties/yml에서 devtools를 비활성화하지 않았는지 확인하세요.
